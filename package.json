{
  "name": "novaforge-ai-blockchain-system",
  "version": "1.0.0",
  "description": "NovaForge AI Blockchain & Token Creator System - The Ultimate AI-Powered Blockchain Platform",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "ai:start": "node ai-empire/orchestrator/init.js",
    "blockchain:start": "node blockchain/nova-chain/start.js",
    "revenue:start": "node revenue/automation/launch.js",
    "test": "jest",
    "test:ai": "jest ai-empire/",
    "test:blockchain": "jest blockchain/",
    "test:revenue": "jest revenue/",
    "build": "npm run build:ai && npm run build:blockchain && npm run build:revenue",
    "build:ai": "webpack --config ai-empire/webpack.config.js",
    "build:blockchain": "webpack --config blockchain/webpack.config.js",
    "build:revenue": "webpack --config revenue/webpack.config.js",
    "deploy": "npm run build && node deployment/deploy.js",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "ai",
    "blockchain",
    "token-creator",
    "autonomous-agents",
    "revenue-generation",
    "defi",
    "crypto",
    "automation",
    "enterprise",
    "novaforge"
  ],
  "author": "Infinite-88",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Infinite-88/emergent--nova.git"
  },
  "dependencies": {
    "express": "^4.18.2",
    "web3": "^4.0.0",
    "@cosmjs/stargate": "^0.32.0",
    "@tensorflow/tfjs-node": "^4.10.0",
    "axios": "^1.5.0",
    "winston": "^3.10.0",
    "redis": "^4.6.0",
    "mongoose": "^7.5.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "socket.io": "^4.7.0",
    "bull": "^4.11.0",
    "helmet": "^7.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.0"
  },
  "devDependencies": {
    "jest": "^29.6.0",
    "nodemon": "^3.0.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0",
    "eslint": "^8.47.0",
    "prettier": "^3.0.0",
    "@types/node": "^20.5.0",
    "typescript": "^5.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}